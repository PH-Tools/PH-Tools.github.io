---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="PH-Tools — Open-Source Passive House Modeling">
  <!-- Hero -->
  <section class="hero graph-paper">
    <h1>PH<span class="accent">-</span>Tools</h1>
    <p class="tagline">
      Open-source tools for Passive House energy modeling. Build, certify, and export — all from Rhino&nbsp;/&nbsp;Grasshopper.
    </p>
    <div class="hero-actions">
      <a href="https://docs.passivehousetools.com" class="btn btn-ghost" target="_blank">Documentation</a>
      <a href="https://github.com/PH-Tools" class="btn btn-ghost" target="_blank">GitHub</a>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="projects">
    <h2>Projects</h2>
    <p class="section-desc">Toolkits and libraries for Passive House workflows.</p>
    <div class="card-grid">
      <a class="service-card" href="/honeybee-ph/">
        <div class="service-card__title">Honeybee-PH</div>
        <div class="service-card__subtitle">Passive House certification modeling</div>
        <div class="service-card__body">
          Add PH-style data to your Honeybee models and export to WUFI-Passive or PHPP.
          Includes install guides, quick start, and tutorials.
        </div>
        <div class="service-card__repos">honeybee_ph &middot; PHX &middot; honeybee_grasshopper_ph</div>
      </a>

      <a class="service-card" href="/honeybee-revive/">
        <div class="service-card__title">Honeybee-Revive</div>
        <div class="service-card__subtitle">Deep energy retrofit analysis</div>
        <div class="service-card__body">
          Retrofit analysis and life-cycle carbon optimization for existing buildings.
          Evaluate improvement scenarios with the ADORB methodology.
        </div>
        <div class="service-card__repos">honeybee_revive &middot; PH-ADORB &middot; honeybee_grasshopper_revive</div>
      </a>

      <a class="service-card" href="https://ph-tools.github.io/CarbonCheck/" target="_blank">
        <div class="service-card__title">CarbonCheck</div>
        <div class="service-card__subtitle">Embodied carbon analysis</div>
        <div class="service-card__body">Evaluate envelope decisions through a carbon lens for building assemblies.</div>
      </a>

      <a class="service-card" href="https://github.com/PH-Tools/PH_Baseliner" target="_blank">
        <div class="service-card__title">PH_Baseliner</div>
        <div class="service-card__subtitle">Baseline energy modeling</div>
        <div class="service-card__body">Generate code-baseline energy models for comparison with Passive House performance targets.</div>
      </a>

      <a class="service-card" href="https://github.com/PH-Tools/PH_units" target="_blank">
        <div class="service-card__title">PH_Units</div>
        <div class="service-card__subtitle">Unit conversions</div>
        <div class="service-card__body">Handle SI/IP conversions for all common building science quantities in Passive House workflows.</div>
      </a>

      <a class="service-card" href="https://github.com/PH-Tools/honeybee_ref" target="_blank">
        <div class="service-card__title">honeybee_ref</div>
        <div class="service-card__subtitle">Reference standards</div>
        <div class="service-card__body">Reference building energy code data and standards for use with Honeybee models.</div>
      </a>
    </div>
  </section>

  <!-- Contact -->
  <section class="getting-started">
    <h2>Get Involved</h2>
    <p class="section-desc">PH-Tools is free and open-source.</p>
    <div class="card-grid">
      <a class="service-card" href="/contact/">
        <div class="service-card__title">Contact</div>
        <div class="service-card__subtitle">Get help</div>
        <div class="service-card__body">Report issues or connect with the PH-Tools community and development team.</div>
      </a>

      <a class="service-card" href="https://github.com/PH-Tools" target="_blank">
        <div class="service-card__title">GitHub</div>
        <div class="service-card__subtitle">Source code</div>
        <div class="service-card__body">Browse repositories, open issues, and contribute to PH-Tools development.</div>
      </a>

      <a class="service-card" href="https://docs.passivehousetools.com" target="_blank">
        <div class="service-card__title">Docs</div>
        <div class="service-card__subtitle">API reference</div>
        <div class="service-card__body">Full documentation for all PH-Tools libraries and components.</div>
      </a>
    </div>
  </section>
</BaseLayout>

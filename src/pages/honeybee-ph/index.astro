---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Honeybee-PH — PH-Tools" activePage="honeybee-ph">
  <!-- Hero -->
  <section class="hero graph-paper">
    <h1>Honeybee<span class="accent">-</span>PH</h1>
    <p class="tagline">
      Passive House energy modeling for Rhino&nbsp;/&nbsp;Grasshopper. Add PH-style data to your Honeybee models,
      then export to WUFI-Passive or PHPP.
    </p>
    <div class="hero-actions">
      <a href="/honeybee-ph/install/" class="btn btn-primary">Get Started</a>
      <a href="https://github.com/PH-Tools/honeybee_grasshopper_ph/releases/latest/download/hbph_installer.ghx" class="btn btn-primary">Download Installer</a>
      <a href="https://docs.passivehousetools.com/honeybee-ph/" class="btn btn-ghost" target="_blank">Documentation</a>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <h2>Why Honeybee-PH?</h2>
    <div class="feature-grid">
      <div class="feature-item">
        <h3>Adds to Existing Workflows</h3>
        <p>Use your existing Honeybee modeling workflows to generate models for Passive House assessment and certification.</p>
      </div>
      <div class="feature-item">
        <h3>Single Model</h3>
        <p>Use one BIM model for all your assessments. From daylighting, to energy, to thermal comfort and full Passive House certification.</p>
      </div>
      <div class="feature-item">
        <h3>Gain Control</h3>
        <p>Configure your mechanical systems, detailed usage programs, and certification settings — all from within the familiar Grasshopper platform.</p>
      </div>
      <div class="feature-item">
        <h3>Make Non-Residential Easy</h3>
        <p>Dramatically simplifies non-residential building modeling with access to the huge Honeybee-Energy program library. Easily manage complex occupancy, lighting, and equipment loads.</p>
      </div>
      <div class="feature-item">
        <h3>Simplify Certification</h3>
        <p>Automate reporting of envelope types, thermal bridges, interior TFA/iCFA, and room-by-room ventilation airflows. Standardize your certification workflow.</p>
      </div>
      <div class="feature-item">
        <h3>WUFI-Passive or PHPP</h3>
        <p>Export to PHPP v9/v10 or WUFI-Passive. Multiple language options (English, Spanish, German) and unit systems (SI, IP).</p>
      </div>
    </div>
  </section>

  <!-- Getting Started -->
  <section class="getting-started">
    <h2>Getting Started</h2>
    <p class="section-desc">Everything you need to start using Honeybee-PH.</p>
    <div class="card-grid">
      <a class="service-card" href="/honeybee-ph/install/">
        <div class="service-card__title">Install</div>
        <div class="service-card__subtitle">Download &amp; setup</div>
        <div class="service-card__body">Install Honeybee-PH and its Grasshopper toolkit. Free and open-source.</div>
      </a>

      <a class="service-card" href="/honeybee-ph/quick-start/">
        <div class="service-card__title">Quick Start</div>
        <div class="service-card__subtitle">Get up and running</div>
        <div class="service-card__body">Add Passive House data to your Rhino / Grasshopper models and export to WUFI-Passive or PHPP.</div>
      </a>

      <a class="service-card" href="https://docs.passivehousetools.com/honeybee-ph/" target="_blank">
        <div class="service-card__title">Docs</div>
        <div class="service-card__subtitle">API reference</div>
        <div class="service-card__body">Full documentation for Honeybee-PH libraries and components.</div>
      </a>

      <a class="service-card" href="/honeybee-ph/resources/">
        <div class="service-card__title">Resources</div>
        <div class="service-card__subtitle">Learn &amp; explore</div>
        <div class="service-card__body">Courses, tutorials, example files, and community links for Passive House modeling.</div>
      </a>
    </div>
  </section>

  <!-- Component Repos -->
  <section class="projects">
    <h2>Repositories</h2>
    <p class="section-desc">The libraries that make up Honeybee-PH.</p>
    <div class="card-grid">
      <a class="service-card" href="https://github.com/PH-Tools/honeybee_ph" target="_blank">
        <div class="service-card__title">honeybee_ph</div>
        <div class="service-card__subtitle">Python data model</div>
        <div class="service-card__body">Extends Ladybug Tools with PH-style attributes for certification with WUFI-Passive or PHPP.</div>
      </a>
      <a class="service-card" href="https://github.com/PH-Tools/PHX" target="_blank">
        <div class="service-card__title">PHX</div>
        <div class="service-card__subtitle">Serialization engine</div>
        <div class="service-card__body">Convert Honeybee-PH models to and from WUFI-Passive XML and PHPP Excel.</div>
      </a>
      <a class="service-card" href="https://github.com/PH-Tools/honeybee_grasshopper_ph" target="_blank">
        <div class="service-card__title">honeybee_grasshopper_ph</div>
        <div class="service-card__subtitle">Grasshopper components</div>
        <div class="service-card__body">User-facing Grasshopper components for building and exporting Passive House models.</div>
      </a>
      <a class="service-card" href="https://github.com/PH-Tools/honeybee_grasshopper_ph_plus" target="_blank">
        <div class="service-card__title">honeybee_grasshopper_ph_plus</div>
        <div class="service-card__subtitle">Extended components</div>
        <div class="service-card__body">Additional Grasshopper components for advanced Passive House workflows.</div>
      </a>
    </div>
  </section>
</BaseLayout>

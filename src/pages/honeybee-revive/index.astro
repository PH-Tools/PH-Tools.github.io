---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Honeybee-Revive — PH-Tools" activePage="honeybee-revive">
  <!-- Hero -->
  <section class="hero graph-paper">
    <h1>Honeybee<span class="accent">-</span>Revive</h1>
    <p class="tagline">
      Deep energy retrofit analysis and life-cycle carbon optimization for existing buildings.
      Evaluate improvement scenarios using the ADORB methodology — all from Rhino&nbsp;/&nbsp;Grasshopper.
    </p>
    <div class="hero-actions">
      <a href="/honeybee-revive/install/" class="btn btn-primary">Get Started</a>
      <a href="https://docs.passivehousetools.com/honeybee-revive/" class="btn btn-ghost" target="_blank">Documentation</a>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <h2>Why Honeybee-Revive?</h2>
    <div class="feature-grid">
      <div class="feature-item">
        <h3>Retrofit Analysis</h3>
        <p>Model existing building conditions and evaluate deep energy retrofit scenarios with full life-cycle carbon accounting.</p>
      </div>
      <div class="feature-item">
        <h3>ADORB Methodology</h3>
        <p>Annualized De-carbonization of Retrofitted Buildings. Optimize retrofit decisions based on carbon payback and cost-effectiveness.</p>
      </div>
      <div class="feature-item">
        <h3>Built on Honeybee</h3>
        <p>Extends your existing Honeybee and Ladybug Tools workflows. No need to learn a new platform — use the tools you already know.</p>
      </div>
      <div class="feature-item">
        <h3>Phased Upgrades</h3>
        <p>Evaluate improvement measures individually or in combination. Model phased upgrade paths to find the optimal retrofit sequence.</p>
      </div>
      <div class="feature-item">
        <h3>Carbon + Cost</h3>
        <p>Combine operational and embodied carbon analysis with financial modeling. Make decisions that balance climate impact with project budgets.</p>
      </div>
      <div class="feature-item">
        <h3>Open Source</h3>
        <p>Free and open-source. Transparent methodology, auditable calculations, and community-driven development.</p>
      </div>
    </div>
  </section>

  <!-- Getting Started -->
  <section class="getting-started">
    <h2>Getting Started</h2>
    <p class="section-desc">Everything you need to start using Honeybee-Revive.</p>
    <div class="card-grid">
      <a class="service-card" href="/honeybee-revive/install/">
        <div class="service-card__title">Install</div>
        <div class="service-card__subtitle">Download &amp; setup</div>
        <div class="service-card__body">Install Honeybee-Revive and its Grasshopper toolkit. Free and open-source.</div>
      </a>

      <a class="service-card" href="https://docs.passivehousetools.com/honeybee-revive/" target="_blank">
        <div class="service-card__title">Docs</div>
        <div class="service-card__subtitle">API reference</div>
        <div class="service-card__body">Full documentation for Honeybee-Revive libraries and components.</div>
      </a>

      <a class="service-card" href="/honeybee-revive/resources/">
        <div class="service-card__title">Resources</div>
        <div class="service-card__subtitle">Learn &amp; explore</div>
        <div class="service-card__body">Presentations, papers, and community links for deep energy retrofit modeling.</div>
      </a>
    </div>
  </section>

  <!-- Component Repos -->
  <section class="projects">
    <h2>Repositories</h2>
    <p class="section-desc">The libraries that make up Honeybee-Revive.</p>
    <div class="card-grid">
      <a class="service-card" href="https://github.com/PH-Tools/honeybee_revive" target="_blank">
        <div class="service-card__title">honeybee_revive</div>
        <div class="service-card__subtitle">Python data model</div>
        <div class="service-card__body">Extends Honeybee with retrofit analysis attributes and life-cycle carbon accounting.</div>
      </a>
      <a class="service-card" href="https://github.com/PH-Tools/PH_ADORB" target="_blank">
        <div class="service-card__title">PH-ADORB</div>
        <div class="service-card__subtitle">Life-cycle optimization</div>
        <div class="service-card__body">Annualized De-carbonization of Retrofitted Buildings. Carbon and cost optimization for retrofit projects.</div>
      </a>
      <a class="service-card" href="https://github.com/PH-Tools/honeybee_grasshopper_revive" target="_blank">
        <div class="service-card__title">honeybee_grasshopper_revive</div>
        <div class="service-card__subtitle">Grasshopper components</div>
        <div class="service-card__body">User-facing Grasshopper components for building and analyzing retrofit scenarios.</div>
      </a>
    </div>
  </section>
</BaseLayout>

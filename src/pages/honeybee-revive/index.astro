---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Honeybee-Revive — PH-Tools" activePage="honeybee-revive">
  <!-- Hero -->
  <section class="hero graph-paper">
    <h1>Honeybee<span class="accent">-</span>Revive</h1>
    <p class="tagline">
      A Grasshopper plugin for deep energy retrofit analysis and life-cycle carbon optimization.
      Add REVIVE-style data to your Honeybee models and calculate ADORB costs directly within Grasshopper.
    </p>
    <div class="hero-actions">
      <a href="/honeybee-revive/install/" class="btn btn-primary">Get Started</a>
      <a href="https://github.com/PH-Tools/honeybee_REVIVE_grasshopper/releases/latest/download/hb_revive_installer.ghx" class="btn btn-primary">Download Installer</a>
      <a href="https://docs.passivehousetools.com/honeybee-revive/" class="btn btn-ghost" target="_blank">Documentation</a>
    </div>
  </section>

  <section class="getting-started">
    <div class="callout warning" style="max-width: 800px; margin: 0 auto;">
      <strong>Please Note:</strong> Honeybee-REVIVE-Grasshopper is in no way affiliated with
      <a href="https://www.phius.org/" target="_blank">Phius</a>, and the library is neither reviewed nor approved
      by Phius for use in complying with the REVIVE program. This library is for <strong>research and testing purposes only</strong>.
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <h2>Why Honeybee-Revive?</h2>
    <div class="feature-grid">
      <div class="feature-item">
        <h3>ADORB Cost Calculation</h3>
        <p>Calculate the Annualized De-carbonization of Retrofitted Buildings (ADORB) cost directly within Grasshopper. Combines operational energy costs, CO<sub>2</sub> emissions costs, construction measure costs, and grid transition costs into a single present-value metric.</p>
      </div>
      <div class="feature-item">
        <h3>Resiliency Simulation</h3>
        <p>Run peak-week resiliency simulations for both summer and winter extreme conditions. Evaluate indoor SET comfort temperatures, heat index, and air quality during grid outage scenarios.</p>
      </div>
      <div class="feature-item">
        <h3>Built on Honeybee</h3>
        <p>Extends your existing Honeybee and Ladybug Tools workflows. Uses EnergyPlus for all simulations — no additional simulation engines required. Compatible with standard Honeybee-Energy components.</p>
      </div>
      <div class="feature-item">
        <h3>Construction Measures</h3>
        <p>Model the full life-cycle cost of construction measures including material purchase, labor, and recurring maintenance and replacement costs over the analysis period.</p>
      </div>
      <div class="feature-item">
        <h3>Carbon + Cost</h3>
        <p>Combine operational and embodied carbon analysis with financial modeling. Account for energy purchase costs, CO<sub>2</sub> emissions costs, and grid transition fees in a single cumulative present-value analysis.</p>
      </div>
      <div class="feature-item">
        <h3>Validated Against Phius GUI</h3>
        <p>Tested against the Phius KMR reference model for both resiliency simulations and ADORB cost calculations. See the <a href="/honeybee-revive/resources/#validation">validation results</a> for detailed comparisons.</p>
      </div>
    </div>
  </section>

  <!-- Getting Started -->
  <section class="getting-started">
    <h2>Getting Started</h2>
    <p class="section-desc">Everything you need to start using Honeybee-Revive.</p>
    <div class="card-grid">
      <a class="service-card" href="/honeybee-revive/install/">
        <div class="service-card__title">Install</div>
        <div class="service-card__subtitle">Download &amp; setup</div>
        <div class="service-card__body">Install Honeybee-Revive and its Grasshopper toolkit. Free and open-source.</div>
      </a>

      <a class="service-card" href="https://docs.passivehousetools.com/honeybee-revive/" target="_blank">
        <div class="service-card__title">Docs</div>
        <div class="service-card__subtitle">API reference</div>
        <div class="service-card__body">Full documentation for Honeybee-Revive libraries and components.</div>
      </a>

      <a class="service-card" href="/honeybee-revive/resources/">
        <div class="service-card__title">Resources</div>
        <div class="service-card__subtitle">Validation &amp; links</div>
        <div class="service-card__body">Validation test cases, model files, and community links for Honeybee-Revive.</div>
      </a>
    </div>
  </section>

  <!-- Component Repos -->
  <section class="projects">
    <h2>Repositories</h2>
    <p class="section-desc">The libraries that make up Honeybee-Revive.</p>
    <div class="card-grid">
      <a class="service-card" href="https://github.com/PH-Tools/honeybee_REVIVE_grasshopper" target="_blank">
        <div class="service-card__title">honeybee_REVIVE_grasshopper</div>
        <div class="service-card__subtitle">Grasshopper components</div>
        <div class="service-card__body">User-facing Grasshopper components for building and analyzing REVIVE retrofit scenarios.</div>
      </a>
      <a class="service-card" href="https://github.com/PH-Tools/honeybee_revive" target="_blank">
        <div class="service-card__title">honeybee_revive</div>
        <div class="service-card__subtitle">Python data model</div>
        <div class="service-card__body">Extends Honeybee with retrofit analysis attributes and life-cycle carbon accounting.</div>
      </a>
      <a class="service-card" href="https://github.com/PH-Tools/PH_ADORB" target="_blank">
        <div class="service-card__title">PH-ADORB</div>
        <div class="service-card__subtitle">ADORB cost engine</div>
        <div class="service-card__body">Annualized De-carbonization of Retrofitted Buildings. Carbon and cost optimization for retrofit projects.</div>
      </a>
    </div>
  </section>
</BaseLayout>
